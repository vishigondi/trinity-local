{
  "manifest_version": 3,
  "name": "Trinity Local Capture",
  "version": "0.1.0",
  "description": "Captures Claude, ChatGPT, and Gemini conversations to ~/.trinity/conversations/. Local-first, no server, no account.",
  "permissions": ["nativeMessaging", "storage"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["adapters/claude.js", "page-hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "minimum_chrome_version": "111"
}
