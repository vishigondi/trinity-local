{
  "manifest_version": 3,
  "name": "Trinity Local",
  "version": "0.2.3",
  "description": "Your taste, ported. Captures conversations from Claude, ChatGPT, and Gemini, and dispatches CLI actions (run council, ingest recent prompts) from the toolbar \u2014 all to your local ~/.trinity/ install. No server, no account.",
  "permissions": [
    "nativeMessaging",
    "storage",
    "tabs"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Trinity Local \u2014 open launchpad or run a quick council",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "popup.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "file:///*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "adapters/claude.js",
        "adapters/chatgpt.js",
        "adapters/gemini.js",
        "page-hook.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "minimum_chrome_version": "111"
}